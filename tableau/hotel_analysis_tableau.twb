              <calculation class='tableau' formula='sum([is_canceled])/COUNT([is_canceled])' />
            </column>
            <column-instance column='[is_canceled]' derivation='Avg' name='[avg:is_canceled:qk]' pivot='key' type='quantitative' />
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Lead Time Group' datatype='string' name='[lead_time_group]' role='dimension' type='nominal'>
