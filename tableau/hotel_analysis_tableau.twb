    <worksheet name='Lead Time vs Cancellation'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='9'>Cancellation Rate by Lead Time &amp; Hotel Type</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>City hotels show consistently higher cancellation rates than resort hotels, especially for bookings made further in advance.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column-instance column='[is_canceled]' derivation='Avg' name='[avg:is_canceled:qk]' pivot='key' type='quantitative' />
            <column caption='Hotel' datatype='string' name='[hotel]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;City Hotel&quot;' value='City' />
                <alias key='&quot;Resort Hotel&quot;' value='Resort' />
              </aliases>
            </column>
            <column caption='Is Canceled' datatype='integer' name='[is_canceled]' role='measure' type='quantitative' />
            <column caption='Lead Time Group' datatype='string' name='[lead_time_group]' role='dimension' type='nominal'>
              <aliases>
                <alias key='&quot;last_min&quot;' value='last min' />
                <alias key='&quot;medium&quot;' value='med' />
                <alias key='&quot;very_long&quot;' value='very long' />
              </aliases>
            </column>
            <column-instance column='[hotel]' derivation='None' name='[none:hotel:nk]' pivot='key' type='nominal' />
            <column-instance column='[lead_time_group]' derivation='None' name='[none:lead_time_group:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[none:hotel:nk]'>
            <groupfilter function='level-members' level='[none:hotel:nk]' user:ui-enumeration='all' user:ui-marker='enumerate' />
          </filter>
          <filter class='categorical' column='[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[none:lead_time_group:nk]'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:lead_time_group:nk]' member='&quot;last_min&quot;' />
              <groupfilter function='member' level='[none:lead_time_group:nk]' member='&quot;long&quot;' />
              <groupfilter function='member' level='[none:lead_time_group:nk]' member='&quot;medium&quot;' />
