    <worksheet name='Lead Time vs ADR'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='10'>ADR by Booking Lead Time </run>
            <run fontalignment='1'>Æ&#10;</run>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='7'>Light green = City Hotel, Dark green = Resort Hotel</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>City hotels consistently charge ADR than resort hotels across all booking lead times, indicating stronger pricing power in urban markets. Customers who book further in advance tend to pay higher rates, while last-minute bookings are associated with lower ADR.</run>
          </formatted-text>
        </caption>
      </layout-options>
