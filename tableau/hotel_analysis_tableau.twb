      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-aliased-fields='true' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:lead_time_group:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;0-7 days&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;last_min&quot;</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>&quot;90+ days&quot;</bucket>
            </map>
            <map to='#9c755f'>
              <bucket>&quot;very_long&quot;</bucket>
            </map>
            <map to='#b07aa1'>
              <bucket>&quot;medium&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;31–90 days&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;long&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;8–30 days&quot;</bucket>
            </map>
            <map to='#ff9da7'>
              <bucket>&quot;short&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:market_segment:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;Aviation&quot;</bucket>
            </map>
            <map to='#59a14f'>
              <bucket>&quot;Groups&quot;</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>&quot;Direct&quot;</bucket>
            </map>
            <map to='#b07aa1'>
              <bucket>&quot;Online TA&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Corporate&quot;</bucket>
            </map>
            <map to='#edc948'>
              <bucket>&quot;Offline TA/TO&quot;</bucket>
