              <bucket>&quot;very_long&quot;</bucket>
              <bucket>&quot;long&quot;</bucket>
              <bucket>&quot;medium&quot;</bucket>
              <bucket>&quot;short&quot;</bucket>
              <bucket>&quot;last_min&quot;</bucket>
            </dictionary>
          </manual-sort>
          <slices>
            <column>[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[none:hotel:nk]</column>
            <column>[federated.1w4my0d11xnlwb1gzdsi10l8qcvk].[none:lead_time_group:nk]</column>
