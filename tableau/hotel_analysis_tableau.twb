    <worksheet name='Total Stay vs Cancellation'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Benton Sans Book' fontsize='11'>Cancellation Volume vs Risk by Length of Stay</run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book' fontsize='8'>Short stays drive volume, but long stays carry higher cancellation risk</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='clean_hotels' name='federated.1w4my0d11xnlwb1gzdsi10l8qcvk' />
          </datasources>
          <datasource-dependencies datasource='federated.1w4my0d11xnlwb1gzdsi10l8qcvk'>
            <column caption='Total_stay_bins' datatype='string' name='[Calculation_0812868189495300]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [total_nights] &lt;= 2 THEN &apos;1-2 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 5 THEN &apos;3-5 nights&apos;&#13;&#10;ELSEIF [total_nights] &lt;= 10 THEN &apos;6-10 nights&apos;&#13;&#10;ELSEIF [total_nights] &gt; 10 THEN &apos;10+ nights&apos;&#13;&#10;END' />
            </column>
